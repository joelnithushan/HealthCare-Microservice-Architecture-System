#=========================================================================
# ENV TEMPLATE — COPY TO .env AND FILL IN YOUR SECRETS
#=========================================================================

# JWT Configuration
# Minimum 32 bytes (256 bits) for HS256. 
JWT_SECRET=your_jwt_secret_key_here
JWT_ACCESS_TOKEN_TTL_MS=86400000
JWT_REFRESH_TOKEN_TTL_MS=604800000

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password


# SMTP Configuration (Gmail App Password)
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Google OAuth (Optional for SSO)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Google Gemini AI (Symptom Checker)
GEMINI_API_KEY=your_gemini_api_key

# Notify.lk SMS Gateway
NOTIFYLK_USER_ID=your_user_id
NOTIFYLK_API_KEY=your_api_key
NOTIFYLK_SENDER_ID=NotifyDEMO

# API Gateway Configuration
GATEWAY_ALLOWED_ORIGIN=http://localhost:3000
GATEWAY_RATE_LIMIT_PER_MINUTE=100
